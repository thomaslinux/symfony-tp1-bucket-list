{% extends 'base.html.twig' %}

{% block body %}

    <h1>Bienvenue sur le site BucketList</h1>
    <h2>liste de trucs à faire</h2>
    <section>

        {% for wish in wishes %}
            <a href="{{ path('wish_detail', {'id': wish.id }) }}">
                <article>
                    {{ wish.title }} - {{ wish.category.name }}
                </article>
            </a>
        {% else %}
            <p>Pas de souhaits !</p>
        {% endfor %}
    </section>
{% endblock %}

{% block title %}
    bucket-list
{% endblock %}

