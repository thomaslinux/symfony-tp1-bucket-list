{% extends 'base.html.twig' %}

{% block body %}
    <article>

        <h3>{{ wish.title }}</h3>
        <em>Created by {{ wish.author }} on {{ wish.dateCreated | date ('Y-m-d') }}</em>
        <br>
        <p class="description">{{ wish.description }}</p>
        <a class="turboBouton link-button" href="{{ path('wish_update', {'id': wish.id}) }}">Update</a>
    </article>


{% endblock %}

{% block title %}
    Wish - {{ wish.title }}
{% endblock %}
